TIMEZONE=America/Buenos_Aires

# Prograrr API Key (required — all API routes require X-Api-Key header)
PROGRARR_API_KEY=your_prograrr_api_key_here

# Request Tracker API Keys
# Get these from Settings > General in each application
JELLYSEERR_API_KEY=your_jellyseerr_api_key_here
SONARR_API_KEY=your_sonarr_api_key_here
RADARR_API_KEY=your_radarr_api_key_here

# qBittorrent credentials
QBITTORRENT_USERNAME=your_username_here
QBITTORRENT_PASSWORD=your_password_here

# SABnzbd (optional — leave API key empty to disable)
SABNZBD_URL=http://localhost:8080
SABNZBD_API_KEY=your_sabnzbd_api_key_here

# CORS (optional — restrict which origins can call the API)
# Leave unset to allow all origins, or set to your frontend URL
# CORS_ORIGIN=http://localhost:3000
